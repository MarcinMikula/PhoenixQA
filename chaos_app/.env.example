# Chaos App config — Vite requires the VITE_ prefix to expose vars to the browser.
# These should mirror CHAOS_LEVEL / SHADOW_DOM_ENABLED in the PhoenixQA root .env
# so both sides (test runner + app under test) agree on the same run.

VITE_CHAOS_LEVEL=MEDIUM          # LOW | MEDIUM | HIGH
VITE_SHADOW_DOM_ENABLED=false    # true | false — independent of CHAOS_LEVEL
